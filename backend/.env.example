# SymptomPal Backend Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Anthropic API (for proactive agent response generation)
# =============================================================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# Google Health AI Developer Foundations (HAI-DEF)
# https://developers.google.com/health-ai-developer-foundations/overview
#
# NOTE: All HAI-DEF models are ENABLED BY DEFAULT and will attempt to use
# the real implementations. If dependencies are missing, they gracefully
# fall back to stubs. Set USE_STUB_*=true to force stub mode for testing.
# =============================================================================

# --- MedASR (Medical Speech Recognition) ---
# Real model ENABLED by default (requires transformers, torch, librosa)
# The model will be downloaded from Hugging Face on first use (~400MB)
# Runs locally - no cloud credentials required
# Set to "true" to force stub mode for testing
USE_STUB_MEDASR=false

# --- MedGemma (Medical Language Model via Vertex AI) ---
# Real model ENABLED by default via Google Vertex AI
# Requires deploying MedGemma to Vertex AI first:
# https://developers.google.com/health-ai-developer-foundations/medgemma/get-started
# Set to "true" to force stub mode for testing
USE_STUB_MEDGEMMA=false

# Optional: run MedGemma locally instead of Vertex AI
# Requires transformers + torch installed and a compatible GPU
USE_LOCAL_MEDGEMMA=false
# Optional: force deterministic response generator output (no LLM JSON parsing)
USE_STUB_RESPONSE_GEN=false
# Optional: use protocolized hybrid follow-up policy (recommended for rollout)
USE_PROTOCOL_FOLLOWUP=false
# Optional: evaluate protocol decisions in logs without changing active output
PROTOCOL_SHADOW_MODE=false
# Local MedGemma model size
MEDGEMMA_MODEL_SIZE=27b
# Optional: override to use a specific HF model ID (e.g., Unsloth)
# MEDGEMMA_MODEL_ID=unsloth/medgemma-27b-text-it-unsloth-bnb-4bit
# If generation is empty, disable chat templating fallback to raw prompt
# MEDGEMMA_DISABLE_CHAT_TEMPLATE=true
# If the model requires custom code on HF
# MEDGEMMA_TRUST_REMOTE_CODE=true

# Google Cloud Project ID (required for MedGemma)
GCP_PROJECT_ID=your_gcp_project_id

# Vertex AI region (default: us-central1)
GCP_REGION=us-central1

# MedGemma Vertex AI Endpoint ID (or fully-qualified resource name)
# Deploy MedGemma to Vertex AI Model Garden first, then copy the endpoint ID.
# Examples:
# - "8725687994146619392"
# - "projects/your-project/locations/us-central1/endpoints/8725687994146619392"
MEDGEMMA_ENDPOINT_ID=your_medgemma_endpoint_id

# Optional: Dedicated endpoint DNS override
# Some Vertex endpoints require calling a dedicated prediction hostname instead of
# the shared `aiplatform.googleapis.com` domain. If you see an error like:
# "Dedicated Endpoint cannot be accessed ... dedicated domain name '...prediction.vertexai.goog'",
# set this to that hostname.
# Example: 8725687994146619392.us-central1-545001441318.prediction.vertexai.goog
# MEDGEMMA_DEDICATED_ENDPOINT_DNS=

# --- HeAR (Health Acoustic Representations) ---
# Real model ENABLED by default for ambient audio classification
# The model will be downloaded from Hugging Face on first use (~500MB)
# Requires accepting the HAI-DEF license terms on Hugging Face
# https://huggingface.co/google/hear
# Set to "true" to force stub mode for testing
USE_STUB_HEAR=false

# Hugging Face token (required for HeAR and MedSigLIP model access)
# Get your token from: https://huggingface.co/settings/tokens
# Must accept HAI-DEF license terms for each model
HF_TOKEN=your_huggingface_token_here

# --- MedSigLIP (Medical Vision-Language Model) ---
# Real model ENABLED by default for medical image analysis
# The model will be downloaded from Hugging Face on first use (~3.5GB)
# Used for analyzing photos of rashes, swelling, skin conditions
# https://huggingface.co/google/medsiglip-448
# Set to "true" to force stub mode for testing
USE_STUB_MEDSIGLIP=false

# =============================================================================
# Application Configuration
# =============================================================================

# API Key for frontend authentication
# Generate a strong random key (e.g., `openssl rand -hex 32`)
API_KEY=your_api_key_here
# Optional: bind API_KEY to one user id to prevent header impersonation
# API_KEY_USER_ID=demo_user
# Optional: multiple key-to-user bindings as JSON (overrides API_KEY/API_KEY_USER_ID)
# API_KEYS_JSON={"key_for_demo_user":"demo_user","key_for_alice":"alice_user"}

# CORS allowed origins (comma-separated)
# Default: http://localhost:5173,http://127.0.0.1:5173
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# Rate limiting (requests per minute per client)
# Set RATE_LIMIT_ENABLED=false to disable
RATE_LIMIT_RPM=60
# RATE_LIMIT_ENABLED=true

# Medication Reminder Time Windows (in minutes)
# Early window: Show reminders this many minutes before scheduled time
REMINDER_EARLY_MINUTES=15
# Late window: Continue showing reminders this many minutes after scheduled time
REMINDER_LATE_MINUTES=60
